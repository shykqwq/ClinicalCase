NODE_ENV=production
PORT=3001
API_PREFIX=api/v1

POSTGRES_PASSWORD=CHANGE_DB_PASSWORD
DATABASE_URL=postgresql://clinical_case:CHANGE_DB_PASSWORD@postgres:5432/clinical_case

JWT_ACCESS_SECRET=CHANGE_TO_A_LONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_TO_A_LONG_RANDOM_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=14d

OBJECT_STORAGE_PROVIDER=s3-compatible
OBJECT_STORAGE_ENDPOINT=
